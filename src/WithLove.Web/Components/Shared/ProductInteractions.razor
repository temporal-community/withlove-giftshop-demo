@rendermode InteractiveServer
@inject ICartService CartService
@inject NavigationManager Navigation

@* Image Gallery *@
<div class="space-y-4">
    <div class="relative overflow-hidden rounded-[2rem] aspect-square bg-stone-100 shadow-xl shadow-stone-200">
        @if (!string.IsNullOrEmpty(selectedImage))
        {
            <img src="@selectedImage"
                 alt="@Product.Name"
                 class="w-full h-full object-cover transition-opacity duration-500" />
        }
        @* Organic shape overlay effect *@
        <div class="absolute inset-0 pointer-events-none rounded-[2rem] ring-1 ring-stone-200/50"></div>
    </div>

    @* Notes of Love *@
    <div class="pt-6 border-t border-stone-200">
        <label class="block text-xs font-bold uppercase tracking-[0.15em] text-stone-400 mb-3">
            Notes of Love
        </label>
        <div class="relative">
            <textarea @bind="personalNote"
                      @bind:event="oninput"
                      maxlength="150"
                      rows="4"
                      placeholder="Write a heartfelt message to accompany your gift..."
                      class="w-full px-4 py-3 bg-white border border-stone-200 rounded-xl text-stone-700 font-handwriting text-base placeholder:text-stone-300 placeholder:font-body resize-none focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all">
            </textarea>
            <div class="absolute bottom-3 right-3 text-xs text-stone-400 font-light">
                @(personalNote?.Length ?? 0)/150
            </div>
        </div>
    </div>

    @* Quantity + Add to Cart *@
    <div class="flex items-center gap-4 pt-2">
        @* Inline quantity selector *@
        <div class="flex items-center rounded-full border border-stone-200 bg-white overflow-hidden">
            <button @onclick="DecrementQuantity"
                    disabled="@(quantity <= 1)"
                    class="w-10 h-10 flex items-center justify-center text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                    aria-label="Decrease quantity">
                <span class="material-symbols-outlined text-base">remove</span>
            </button>
            <span class="w-10 text-center text-sm font-medium text-stone-800 select-none">@quantity</span>
            <button @onclick="IncrementQuantity"
                    class="w-10 h-10 flex items-center justify-center text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-colors"
                    aria-label="Increase quantity">
                <span class="material-symbols-outlined text-base">add</span>
            </button>
        </div>

        @* Add to Collection button *@
        <button @onclick="AddToCart"
                disabled="@isAdding"
                class="flex-1 bg-stone-800 text-stone-50 px-8 py-3.5 rounded-full text-sm font-bold uppercase tracking-wider hover:bg-primary transition-all shadow-md shadow-stone-300/50 disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2">
            @if (isAdding)
            {
                <span class="material-symbols-outlined text-base animate-spin">progress_activity</span>
                <span>Adding...</span>
            }
            else if (justAdded)
            {
                <span class="material-symbols-outlined text-base">check</span>
                <span>Added!</span>
            }
            else
            {
                <span class="material-symbols-outlined text-base">favorite_border</span>
                <span>Add to Collection</span>
            }
        </button>
    </div>

    @if (!string.IsNullOrEmpty(errorMessage))
    {
        <p class="text-sm text-red-500 mt-2">@errorMessage</p>
    }
</div>

@code {
    [Parameter, EditorRequired]
    public Product Product { get; set; } = default!;

    private string? selectedImage;
    private string? personalNote;
    private int quantity = 1;
    private bool isAdding;
    private bool justAdded;
    private string? errorMessage;

    protected override void OnParametersSet()
    {
        selectedImage = Product.ImageUrl;
    }

    private void IncrementQuantity()
    {
        quantity++;
    }

    private void DecrementQuantity()
    {
        if (quantity > 1) quantity--;
    }

    private async Task AddToCart()
    {
        isAdding = true;
        errorMessage = null;
        try
        {
            var item = new CartItem
            {
                ProductId = Product.Id,
                ProductName = Product.Name,
                ImageUrl = selectedImage ?? Product.ImageUrl ?? string.Empty,
                StripePriceId = Product.StripePriceId,
                Price = Product.Price,
                Quantity = quantity,
                PersonalNote = personalNote
            };
            await CartService.AddItemAsync(item);
            justAdded = true;
            await Task.Delay(900);
            Navigation.NavigateTo("/cart");
        }
        catch (Exception)
        {
            errorMessage = "Something went wrong. Please try again.";
        }
        finally
        {
            isAdding = false;
        }
    }
}
