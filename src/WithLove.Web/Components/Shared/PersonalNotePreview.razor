@* PersonalNotePreview.razor - Live preview of the personal message card *@

<div class="bg-stone-50 rounded-2xl border border-stone-200 overflow-hidden">
    <div class="px-5 py-4 border-b border-stone-200 bg-white">
        <p class="text-xs font-bold uppercase tracking-[0.15em] text-stone-400">Note Preview</p>
    </div>

    @* Faux card *@
    <div class="p-6">
        <div class="bg-white rounded-xl shadow-sm border border-stone-100 p-6 min-h-[140px] relative">
            @* Decorative corner *@
            <div class="absolute top-3 right-3">
                <span class="material-symbols-outlined text-primary/30 text-2xl">favorite</span>
            </div>

            @if (!string.IsNullOrEmpty(RecipientName))
            {
                <p class="text-stone-400 text-xs font-light mb-3">Dear @RecipientName,</p>
            }

            @if (!string.IsNullOrEmpty(Message))
            {
                <p class="font-handwriting text-stone-700 text-lg leading-relaxed whitespace-pre-wrap">@Message</p>
            }
            else
            {
                <p class="text-stone-300 font-handwriting text-lg italic leading-relaxed">
                    Your heartfelt message will appear here...
                </p>
            }

            @* Signature line *@
            <div class="mt-4 pt-3 border-t border-stone-100">
                <p class="text-stone-300 text-xs font-light italic text-right">With Love</p>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter]
    public string Message { get; set; } = string.Empty;

    [Parameter]
    public string RecipientName { get; set; } = string.Empty;
}
