@* CartItemRow.razor - Individual cart item row *@

<div class="flex gap-4 sm:gap-6 py-6 border-b border-stone-100 last:border-0 group">
    @* Product Image *@
    <a href="/product/@Item.ProductId" class="flex-shrink-0">
        <div class="w-20 h-20 sm:w-24 sm:h-24 rounded-xl overflow-hidden bg-stone-100">
            @if (!string.IsNullOrEmpty(Item.ImageUrl))
            {
                <img src="@Item.ImageUrl"
                     alt="@Item.ProductName"
                     class="w-full h-full object-cover hover:scale-105 transition-transform duration-300" />
            }
        </div>
    </a>

    @* Product Info *@
    <div class="flex-1 min-w-0">
        <div class="flex items-start justify-between gap-2">
            <div>
                <a href="/product/@Item.ProductId">
                    <h3 class="font-display text-lg text-stone-800 hover:text-primary transition-colors leading-tight">@Item.ProductName</h3>
                </a>
                @if (!string.IsNullOrEmpty(Item.PersonalNote))
                {
                    <p class="text-stone-500 text-xs font-handwriting mt-1 line-clamp-1 italic">"@Item.PersonalNote"</p>
                }
            </div>
            <span class="text-stone-800 font-display text-lg flex-shrink-0">@((Item.Price * Item.Quantity).ToString("C"))</span>
        </div>

        <div class="flex items-center justify-between mt-4">
            @* Quantity controls *@
            <div class="flex items-center rounded-full border border-stone-200 bg-white overflow-hidden">
                <button @onclick="@(() => OnQuantityChanged.InvokeAsync((Item.ProductId, Item.Quantity - 1)))"
                        disabled="@(Item.Quantity <= 1)"
                        class="w-8 h-8 flex items-center justify-center text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-colors disabled:opacity-30 disabled:cursor-not-allowed"
                        aria-label="Decrease quantity">
                    <span class="material-symbols-outlined text-sm">remove</span>
                </button>
                <span class="w-8 text-center text-sm font-medium text-stone-800 select-none">@Item.Quantity</span>
                <button @onclick="@(() => OnQuantityChanged.InvokeAsync((Item.ProductId, Item.Quantity + 1)))"
                        class="w-8 h-8 flex items-center justify-center text-stone-500 hover:text-stone-800 hover:bg-stone-50 transition-colors"
                        aria-label="Increase quantity">
                    <span class="material-symbols-outlined text-sm">add</span>
                </button>
            </div>

            @* Remove button *@
            <button @onclick="@(() => OnRemove.InvokeAsync(Item.ProductId))"
                    class="text-stone-400 hover:text-red-400 transition-colors text-xs flex items-center gap-1"
                    aria-label="Remove item">
                <span class="material-symbols-outlined text-sm">delete_outline</span>
                <span class="hidden sm:inline">Remove</span>
            </button>
        </div>
    </div>
</div>

@code {
    [Parameter, EditorRequired]
    public CartItem Item { get; set; } = default!;

    [Parameter]
    public EventCallback<(int ProductId, int Quantity)> OnQuantityChanged { get; set; }

    [Parameter]
    public EventCallback<int> OnRemove { get; set; }
}
