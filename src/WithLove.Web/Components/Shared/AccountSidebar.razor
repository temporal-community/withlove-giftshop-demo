<aside class="w-full lg:w-72 lg:fixed lg:h-[calc(100vh-6rem)] border-r border-stone-100 bg-white/30 p-8 lg:p-10 space-y-12">
    <div class="space-y-1">
        <p class="text-[10px] uppercase tracking-[0.2em] text-stone-400 mb-6 font-semibold">My Account</p>
        <nav class="space-y-2">
            <a href="/account/profile"
               class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 @(ActivePage == "profile" ? "bg-stone-100 text-stone-800 shadow-sm" : "text-stone-500 hover:text-stone-800 hover:bg-stone-50")">
                <span class="material-symbols-outlined text-xl font-light">person</span>
                <span class="text-sm font-medium">Profile Details</span>
            </a>
            <a href="/account/orders"
               class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 @(ActivePage == "orders" ? "bg-stone-100 text-stone-800 shadow-sm" : "text-stone-500 hover:text-stone-800 hover:bg-stone-50")">
                <span class="material-symbols-outlined text-xl font-light">history</span>
                <span class="text-sm font-medium">Order History</span>
            </a>
            <a href="/account/addresses"
               class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 @(ActivePage == "addresses" ? "bg-stone-100 text-stone-800 shadow-sm" : "text-stone-500 hover:text-stone-800 hover:bg-stone-50")">
                <span class="material-symbols-outlined text-xl font-light">location_on</span>
                <span class="text-sm font-medium">Addresses</span>
            </a>
            <a href="/account/profile/profile"
               class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 @(ActivePage == "wishlist" ? "bg-stone-100 text-stone-800 shadow-sm" : "text-stone-500 hover:text-stone-800 hover:bg-stone-50")">
                <span class="material-symbols-outlined text-xl font-light">favorite_border</span>
                <span class="text-sm font-medium">Wishlist</span>
            </a>
            <a href="/account/profile/profile"
               class="flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-300 @(ActivePage == "preferences" ? "bg-stone-100 text-stone-800 shadow-sm" : "text-stone-500 hover:text-stone-800 hover:bg-stone-50")">
                <span class="material-symbols-outlined text-xl font-light">settings</span>
                <span class="text-sm font-medium">Preferences</span>
            </a>
        </nav>
    </div>
    <div class="pt-10 border-t border-stone-100">
        <form method="post" action="/logout">
            <AntiforgeryToken />
            <button type="submit" class="w-full flex items-center gap-3 px-4 py-3 rounded-xl text-stone-400 hover:text-red-400 transition-all duration-300">
                <span class="material-symbols-outlined text-xl font-light">logout</span>
                <span class="text-sm font-medium">Log Out</span>
            </button>
        </form>
    </div>
</aside>

@code {
    [Parameter, EditorRequired]
    public string ActivePage { get; set; } = "";
}
