@page "/login"
@layout LoginLayout
@using Microsoft.AspNetCore.Identity
@using WithLove.Data.Models
@using System.ComponentModel.DataAnnotations
@inject SignInManager<ShopUser> SignInManager
@inject NavigationManager Navigation
@inject ILogger<Login> Logger

<PageTitle>Login | With Love</PageTitle>

<div class="flex min-h-screen">
    <!-- Left Panel - Brand -->
    <div class="hidden lg:flex lg:w-1/2 relative overflow-hidden bg-lavender-mist items-center justify-center p-16">
        <div class="absolute inset-0 bg-grain mix-blend-multiply pointer-events-none"></div>
        <div class="absolute inset-0 texture-overlay pointer-events-none"></div>
        <div
            class="absolute top-0 right-0 w-full h-full bg-white/20 organic-shape-bg -translate-y-1/4 translate-x-1/4 blur-2xl">
        </div>
        <div
            class="absolute bottom-0 left-0 w-3/4 h-3/4 bg-primary/5 organic-shape-1 translate-y-1/4 -translate-x-1/4 blur-xl">
        </div>
        <div
            class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[120%] h-[120%] bg-white/10 blur-[120px] rounded-full">
        </div>

        <a class="absolute top-12 left-12 font-display text-2xl tracking-widest text-stone-800 flex items-center gap-2 group z-20"
               href="/">
            <span
            class="material-symbols-outlined text-primary font-light text-2xl group-hover:scale-110 transition-transform">spa</span>
            <span>with love</span>
        </a>

        <div class="relative z-10 w-full max-w-lg text-center space-y-12">
            <div class="space-y-6">
                <span class="text-[10px] uppercase tracking-[0.4em] text-primary-dark font-bold">Brand Philosophy</span>
                <h2 class="text-5xl lg:text-6xl text-stone-800 leading-tight font-display italic">Essence of Grace</h2>
                <div class="w-12 h-[1px] bg-primary mx-auto opacity-60"></div>
                <p class="text-stone-600 font-light text-lg leading-relaxed max-w-md mx-auto font-sans">
                    We curate experiences that honor the rhythm of the natural world. Our core values reside in the
                    quiet strength of intentional design and the gentle beauty found in life's most fleeting moments.
                </p>
            </div>
            <div class="grid grid-cols-3 gap-8 pt-8 border-t border-stone-800/10">
                <div class="space-y-2">
                    <span class="block font-display text-lg text-stone-800">Mindful</span>
                    <span class="block text-[10px] uppercase tracking-widest text-stone-500">Creation</span>
                </div>
                <div class="space-y-2">
                    <span class="block font-display text-lg text-stone-800">Organic</span>
                    <span class="block text-[10px] uppercase tracking-widest text-stone-500">Growth</span>
                </div>
                <div class="space-y-2">
                    <span class="block font-display text-lg text-stone-800">Pure</span>
                    <span class="block text-[10px] uppercase tracking-widest text-stone-500">Intention</span>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Panel - Login Form -->
    <div class="w-full lg:w-1/2 flex items-center justify-center p-6 sm:p-12 md:p-20 relative">
        <div class="w-full max-w-md space-y-10 relative z-10">
            <!-- Mobile Logo -->
            <div class="lg:hidden flex justify-center mb-8">
                <a class="font-display text-2xl tracking-widest text-stone-800 flex items-center gap-2" href="/">
                    <span class="material-symbols-outlined text-primary font-light text-2xl">spa</span>
                    <span>with love</span>
                </a>
            </div>

            <div class="text-center space-y-3">
                <h1 class="text-4xl font-display text-stone-800">Welcome Back</h1>
                <p class="text-stone-500 font-light italic">Sign in to your curator account</p>
            </div>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <div class="bg-red-50 border border-red-100 rounded-2xl px-6 py-4 text-sm text-red-600 font-light">
                    @_errorMessage
                </div>
            }

            <EditForm Model="Input" FormName="login" OnValidSubmit="LoginUser" method="post" class="space-y-6">
                <DataAnnotationsValidator />

                <div class="space-y-4">
                    <div class="relative group">
                        <label class="text-[10px] uppercase tracking-widest text-stone-400 font-bold ml-4 mb-1 block"
                               for="email">Email Address</label>
                        <InputText @bind-Value="Input.Email" id="email" placeholder="hello@example.com" type="email"
                                   class="w-full bg-white border-stone-200 rounded-full px-6 py-4 text-sm text-stone-700 placeholder-stone-300 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" />
                        <ValidationMessage For="() => Input.Email" class="text-xs text-red-400 ml-4 mt-1" />
                    </div>
                    <div class="relative group">
                        <div class="flex justify-between items-center ml-4 mb-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-bold block"
                                   for="password">Password</label>
                            <a class="text-[10px] uppercase tracking-widest text-primary hover:text-primary-dark transition-colors font-bold"
                               href="#">Forgot?</a>
                        </div>
                        <InputText @bind-Value="Input.Password" id="password" placeholder="••••••••" type="password"
                                   class="w-full bg-white border-stone-200 rounded-full px-6 py-4 text-sm text-stone-700 placeholder-stone-300 focus:ring-1 focus:ring-primary focus:border-primary transition-all outline-none" />
                        <ValidationMessage For="() => Input.Password" class="text-xs text-red-400 ml-4 mt-1" />
                    </div>
                </div>

                <button type="submit"
                        class="w-full bg-stone-800 text-stone-50 py-4 rounded-full text-sm uppercase tracking-widest font-bold hover:bg-primary transition-all duration-300 shadow-lg shadow-stone-200 transform active:scale-[0.98]">
                    Sign In
                </button>
            </EditForm>

            <div class="text-center pt-4">
                <p class="text-sm text-stone-500 font-light">
                    Don't have an account?
                    <a class="text-primary font-bold hover:text-primary-dark transition-colors ml-1"
                           href="@($"/register{(!string.IsNullOrEmpty(ReturnUrl) ? $"?returnUrl={Uri.EscapeDataString(ReturnUrl)}" : "")}")">Create
                        one</a>
                    </p>
                </div>
            </div>

            <div class="absolute top-20 right-20 w-32 h-32 bg-primary/10 rounded-full blur-3xl -z-10"></div>
            <div class="absolute bottom-20 left-20 w-48 h-48 bg-clay/5 rounded-full blur-3xl -z-10"></div>
        </div>
    </div>

    <!-- Back to shop -->
    <a class="fixed bottom-12 right-12 text-stone-400 hover:text-stone-800 transition-colors flex items-center gap-2 group z-50"
           href="/">
        <span
            class="text-[10px] uppercase tracking-widest font-bold border-b border-transparent group-hover:border-stone-800 transition-all">Back
            to shop</span>
            <span class="material-symbols-outlined text-sm">arrow_forward</span>
        </a>

@code {
    private string? _errorMessage;

    [SupplyParameterFromForm]
    private LoginInput Input { get; set; } = default!;

    protected override void OnInitialized()
    {
        Input ??= new();
    }

    [SupplyParameterFromQuery(Name = "returnUrl")]
    private string? ReturnUrl { get; set; }

    private async Task LoginUser()
    {
        var result = await SignInManager.PasswordSignInAsync(
            Input.Email!, Input.Password!, isPersistent: false, lockoutOnFailure: false);

        if (result.Succeeded)
        {
            Logger.LogInformation("User {Email} logged in.", Input.Email);
            Navigation.NavigateTo(ReturnUrl ?? "/", forceLoad: true);
        }
        else
        {
            _errorMessage = "Invalid email or password. Please try again.";
            Logger.LogWarning("Failed login attempt for {Email}.", Input.Email);
        }
    }

    private sealed class LoginInput
    {
        [Required(ErrorMessage = "Email is required.")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address.")]
        public string? Email { get; set; }

        [Required(ErrorMessage = "Password is required.")]
        public string? Password { get; set; }
    }
}
