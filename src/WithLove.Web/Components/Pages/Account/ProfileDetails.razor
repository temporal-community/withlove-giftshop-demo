@page  "/account"
@page "/account/profile"
@attribute [Authorize]

<PageTitle>Profile Details | With Love</PageTitle>

<div class="min-h-[calc(100vh-6rem)] flex flex-col lg:flex-row">
    <AccountSidebar ActivePage="profile" />

    <div class="flex-1 lg:ml-72 p-6 lg:p-16">
        <div class="max-w-5xl mx-auto">
            <!-- Page Header -->
            <div class="mb-12">
                <h1 class="text-3xl md:text-4xl font-display text-stone-800 mb-2">Profile Details</h1>
                <p class="text-sm text-stone-400 font-light">Manage your personal information and account security settings.</p>
            </div>

            <div class="grid grid-cols-1 gap-8">
                <!-- Personal Information -->
                <div class="bg-white border border-stone-100 rounded-3xl p-6 md:p-10 hover:shadow-xl hover:shadow-stone-100/50 transition-all duration-500">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 pb-6 border-b border-stone-50">
                        <div>
                            <h2 class="text-xl font-display text-stone-800 mb-1">Personal Information</h2>
                            <p class="text-xs text-stone-400 font-light tracking-wide uppercase">Your identity and contact details</p>
                        </div>
                        <button class="px-6 py-2.5 rounded-full border border-stone-200 text-xs font-bold uppercase tracking-widest text-stone-600 hover:bg-stone-50 transition-colors">Edit</button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Full Name</label>
                            <p class="text-stone-800 font-medium">Eleanor Whispering-Woods</p>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Email Address</label>
                            <p class="text-stone-800 font-medium">eleanor.w@@serenity.com</p>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Phone Number</label>
                            <p class="text-stone-800 font-medium">+1 (555) 012-3456</p>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Birthday</label>
                            <p class="text-stone-800 font-medium">March 14th</p>
                        </div>
                    </div>
                </div>

                <!-- Security & Login -->
                <div class="bg-white border border-stone-100 rounded-3xl p-6 md:p-10 hover:shadow-xl hover:shadow-stone-100/50 transition-all duration-500">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 pb-6 border-b border-stone-50">
                        <div>
                            <h2 class="text-xl font-display text-stone-800 mb-1">Security &amp; Login</h2>
                            <p class="text-xs text-stone-400 font-light tracking-wide uppercase">Manage your credentials</p>
                        </div>
                        <button class="px-6 py-2.5 rounded-full border border-stone-200 text-xs font-bold uppercase tracking-widest text-stone-600 hover:bg-stone-50 transition-colors">Edit</button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Password</label>
                            <div class="flex items-center gap-2">
                                <p class="text-stone-800 font-medium">&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;&#x2022;</p>
                                <span class="text-[10px] text-stone-400 italic font-light">Last changed 3 months ago</span>
                            </div>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Two-Factor Authentication</label>
                            <p class="text-sage-green font-medium flex items-center gap-1.5">
                                <span class="material-symbols-outlined text-sm">verified_user</span>
                                Enabled
                            </p>
                        </div>
                    </div>
                </div>

                <!-- Communication Preferences -->
                <div class="bg-white border border-stone-100 rounded-3xl p-6 md:p-10 hover:shadow-xl hover:shadow-stone-100/50 transition-all duration-500">
                    <div class="flex flex-col md:flex-row justify-between items-start md:items-center gap-6 mb-8 pb-6 border-b border-stone-50">
                        <div>
                            <h2 class="text-xl font-display text-stone-800 mb-1">Communication Preferences</h2>
                            <p class="text-xs text-stone-400 font-light tracking-wide uppercase">Tailor your inbox experience</p>
                        </div>
                        <button class="px-6 py-2.5 rounded-full border border-stone-200 text-xs font-bold uppercase tracking-widest text-stone-600 hover:bg-stone-50 transition-colors">Edit</button>
                    </div>
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-8">
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Newsletter Status</label>
                            <p class="text-stone-800 font-medium">Subscribed to 'The Journal'</p>
                        </div>
                        <div class="space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">SMS Notifications</label>
                            <p class="text-stone-500 font-medium italic">Not currently active</p>
                        </div>
                        <div class="md:col-span-2 space-y-1">
                            <label class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold">Marketing Consents</label>
                            <p class="text-stone-800 font-medium text-sm leading-relaxed max-w-2xl">Receiving monthly collection previews and occasional artisanal stories.</p>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Bottom CTA -->
            <div class="mt-20 text-center space-y-4">
                <p class="text-stone-400 text-sm font-light italic">"The beauty of a story is in its details."</p>
                <a href="/account/orders" class="text-xs uppercase tracking-widest text-stone-500 hover:text-primary border-b border-stone-200 hover:border-primary transition-all pb-1">View Recent Orders</a>
            </div>
        </div>
    </div>
</div>
