@page "/account/orders/{ConfirmationNumber}"
@attribute [Authorize]
@rendermode InteractiveServer
@using System.Security.Claims

<PageTitle>Order @ConfirmationNumber | With Love</PageTitle>

<div class="min-h-[calc(100vh-6rem)] flex flex-col lg:flex-row">
    <AccountSidebar ActivePage="orders" />

    <div class="flex-1 lg:ml-72 p-6 lg:p-16">
        <div class="max-w-3xl mx-auto">

            <!-- Back link -->
            <div class="mb-8">
                <a href="/account/orders" class="inline-flex items-center gap-2 text-xs uppercase tracking-widest text-stone-400 hover:text-stone-700 transition-colors">
                    <span class="material-symbols-outlined text-base">arrow_back</span>
                    Back to Order History
                </a>
            </div>

            @if (_loading)
            {
                <div class="flex items-center justify-center gap-3 py-20 text-stone-400">
                    <span class="material-symbols-outlined text-2xl animate-spin">progress_activity</span>
                    <span class="text-sm font-light">Loading order details...</span>
                </div>
            }
            else if (_loadError)
            {
                <div class="bg-red-50 border border-red-100 rounded-2xl p-6 text-center space-y-4">
                    <p class="text-sm text-red-600">Something went wrong loading your order. Please try again.</p>
                    <a href="/account/orders" class="text-xs uppercase tracking-widest text-stone-500 hover:text-primary border-b border-stone-200 hover:border-primary transition-all pb-1">Back to Order History</a>
                </div>
            }
            else if (_order is null)
            {
                <div class="bg-stone-50 border border-stone-100 rounded-3xl p-12 text-center space-y-4">
                    <span class="material-symbols-outlined text-4xl text-stone-300">search_off</span>
                    <p class="text-stone-500 font-light">Order not found.</p>
                    <a href="/account/orders" class="inline-block text-xs uppercase tracking-widest text-stone-500 hover:text-primary border-b border-stone-200 hover:border-primary transition-all pb-1">Back to Order History</a>
                </div>
            }
            else
            {
                <!-- Page Header -->
                <div class="mb-10">
                    <div class="flex flex-wrap items-center gap-3 mb-2">
                        <h1 class="text-3xl md:text-4xl font-display text-stone-800">@_order.ConfirmationNumber</h1>
                        <span class="px-3 py-1 bg-sage-green/10 text-sage-green text-[10px] uppercase tracking-widest font-bold rounded-full">@_order.Status</span>
                    </div>
                    <p class="text-sm text-stone-400 font-light">Placed on @_order.PlacedAt.ToString("MMMM d, yyyy")</p>
                </div>

                <!-- Reorder warning banner -->
                @if (_reorderWarning is not null)
                {
                    <div class="mb-6 bg-amber-50 border border-amber-100 rounded-2xl p-4 flex items-start gap-3">
                        <span class="material-symbols-outlined text-amber-400 shrink-0 mt-0.5">warning</span>
                        <div class="flex-1 min-w-0">
                            <p class="text-sm text-amber-800">@_reorderWarning</p>
                            <a href="/cart" class="mt-2 inline-block text-xs font-semibold uppercase tracking-widest text-primary hover:text-primary-dark transition-colors">Go to Cart →</a>
                        </div>
                        <button @onclick="() => _reorderWarning = null"
                                class="shrink-0 text-amber-500 hover:text-amber-700 transition-colors"
                                aria-label="Dismiss">
                            <span class="material-symbols-outlined text-xl">close</span>
                        </button>
                    </div>
                }

                <!-- Line Items -->
                <div class="bg-white border border-stone-100 rounded-3xl p-6 md:p-8 hover:shadow-xl hover:shadow-stone-100/50 transition-all duration-500">
                    <h2 class="font-display text-xl text-stone-800 mb-6 pb-4 border-b border-stone-50">Items Ordered</h2>

                    <div class="space-y-4">
                        @foreach (var item in _order.LineItems)
                        {
                            <div class="flex items-center gap-4 @(item.IsEnhancement ? "opacity-75" : "")">
                                <!-- Product image or gift enhancement icon -->
                                <div class="shrink-0 h-16 w-16 rounded-2xl bg-stone-100 overflow-hidden flex items-center justify-center">
                                    @if (item.ImageUrl is not null)
                                    {
                                        <img src="@item.ImageUrl" alt="@item.ProductName" class="h-full w-full object-cover" />
                                    }
                                    else
                                    {
                                        <span class="material-symbols-outlined text-2xl text-stone-400">card_giftcard</span>
                                    }
                                </div>
                                <!-- Item details -->
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-medium text-stone-800 truncate">@item.ProductName</p>
                                    @if (item.IsEnhancement)
                                    {
                                        <p class="text-[10px] uppercase tracking-widest text-stone-400 font-semibold mt-0.5">Gift Enhancement</p>
                                    }
                                    <p class="text-xs text-stone-500 font-light mt-0.5">Qty: @item.Quantity &times; @item.UnitPrice.ToString("C")</p>
                                </div>
                                <!-- Line total -->
                                <div class="shrink-0 text-right">
                                    <p class="text-sm font-semibold text-stone-800">@((item.Quantity * item.UnitPrice).ToString("C"))</p>
                                </div>
                            </div>
                        }
                    </div>

                    <!-- Order Total + Reorder -->
                    <hr class="my-6 border-stone-100" />
                    <div class="flex flex-wrap items-center justify-between gap-4">
                        <div>
                            <p class="text-sm font-bold uppercase tracking-widest text-stone-500">Order Total</p>
                            <p class="text-xl font-display font-semibold text-stone-800 mt-1">@_order.AmountTotal.ToString("C")</p>
                        </div>
                        <div class="flex flex-col items-end gap-2">
                            <button @onclick="ReorderAsync" disabled="@_reordering"
                                    class="px-6 py-2.5 bg-primary hover:bg-primary-dark text-white text-xs font-semibold uppercase tracking-widest rounded-full transition-colors disabled:opacity-50 disabled:cursor-not-allowed">
                                @(_reordering ? "Adding to Cart..." : "Reorder")
                            </button>
                            @if (_reorderError)
                            {
                                <p class="text-xs text-red-500">Something went wrong. Please try again.</p>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

@code {
    /// <summary>The "WL-XXXXXXX" confirmation number from the URL route.</summary>
    [Parameter] public string ConfirmationNumber { get; set; } = "";

    [Inject] private AuthenticationStateProvider AuthStateProvider { get; set; } = default!;
    [Inject] private IOrderService OrderService { get; set; } = default!;
    [Inject] private ICartService CartService { get; set; } = default!;
    [Inject] private IProductService ProductService { get; set; } = default!;
    [Inject] private NavigationManager Nav { get; set; } = default!;

    private OrderDetailView? _order;
    private bool _loading = true;
    private bool _loadError;
    private bool _reordering;
    private string? _reorderWarning;
    private bool _reorderError;

    protected override async Task OnInitializedAsync()
    {
        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";
        try
        {
            // ConfirmationNumber arrives URL-decoded by Blazor routing (e.g., "WL-XXXXXXX").
            // URL-safe alphanumeric — no percent-decoding needed.
            _order = await OrderService.GetOrderAsync(userId, ConfirmationNumber);
        }
        catch { _loadError = true; }
        finally { _loading = false; }
    }

    private async Task ReorderAsync()
    {
        if (_reordering || _order is null) return;
        _reordering = true;
        _reorderError = false;
        _reorderWarning = null;
        try
        {
            var auth = await AuthStateProvider.GetAuthenticationStateAsync();
            var userId = auth.User.FindFirst(ClaimTypes.NameIdentifier)?.Value ?? "";

            // FusionCacheCartService requires InitializeAsync before any mutation.
            await CartService.InitializeAsync(userId);

            // _order already has full line items — no second GetOrderAsync call needed.
            var allProducts = await ProductService.GetProductsAsync();
            var catalogById = allProducts.ToDictionary(p => p.Id);

            var unavailable = new List<string>();
            foreach (var item in _order.LineItems.Where(li => !li.IsEnhancement && li.ProductId.HasValue))
            {
                if (!catalogById.TryGetValue(item.ProductId!.Value, out var product) ||
                    string.IsNullOrWhiteSpace(product.StripePriceId))
                {
                    unavailable.Add(item.ProductName);
                    continue;
                }
                await CartService.AddItemAsync(new CartItem
                {
                    ProductId = product.Id,
                    ProductName = product.Name,
                    ImageUrl = product.ImageUrl ?? "",
                    Price = product.Price,
                    StripePriceId = product.StripePriceId,
                    Quantity = item.Quantity
                });
            }

            if (unavailable.Count > 0)
            {
                _reorderWarning = $"{unavailable.Count} item(s) from your original order " +
                    $"are no longer available and were not added: {string.Join(", ", unavailable)}.";
                return;
            }
            Nav.NavigateTo("/cart");
        }
        catch { _reorderError = true; }
        finally { _reordering = false; }
    }
}
