@page "/collections"
@page "/collections/{CategoryId:int}"
@attribute [StreamRendering]
@inject IProductService ProductService

<PageTitle>@(category?.Name ?? "Our Collections") | With Love</PageTitle>

@* Hero Banner *@
<section class="relative h-48 md:h-60 lg:h-72 overflow-hidden flex items-end">
    @if (CategoryId.HasValue && category is not null)
    {
        <div class="absolute inset-0">
            <img src="@(category.HeroImage ?? category.Image)"
                 alt="@category.Name"
                 class="w-full h-full object-cover" />
            <div class="absolute inset-0 bg-gradient-to-t from-stone-900/70 via-stone-900/30 to-transparent"></div>
            <div class="absolute inset-0 backdrop-blur-[2px]" style="background: linear-gradient(to top, rgba(28,25,23,0.65) 0%, rgba(28,25,23,0.1) 60%, transparent 100%)"></div>
        </div>
        <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-12 w-full pb-10">
            <Breadcrumb Items="@(new List<BreadcrumbItem> { new BreadcrumbItem("Home", "/"), new BreadcrumbItem(category.Name, null) })" Light="true" />
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-display text-white mt-3 drop-shadow-lg">
                @(category.HeroTitle ?? category.Name)
            </h1>
            @if (!string.IsNullOrEmpty(category.HeroSubtitle))
            {
                <p class="text-white/80 text-lg font-light mt-2 max-w-xl">@category.HeroSubtitle</p>
            }
        </div>
    }
    else if (!CategoryId.HasValue && products is not null)
    {
        <div class="absolute inset-0 bg-gradient-to-br from-stone-800 via-stone-700 to-stone-800"></div>
        <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-12 w-full pb-10">
            <Breadcrumb Items="@(new List<BreadcrumbItem> { new BreadcrumbItem("Home", "/"), new BreadcrumbItem("Collections", null) })" Light="true" />
            <h1 class="text-4xl md:text-5xl lg:text-6xl font-display text-white mt-3 drop-shadow-lg">
                Our Collections
            </h1>
            <p class="text-white/80 text-lg font-light mt-2 max-w-xl">Thoughtfully curated gifts for every occasion.</p>
        </div>
    }
    else
    {
        <div class="absolute inset-0 bg-stone-200 animate-pulse"></div>
        <div class="relative z-10 max-w-[1400px] mx-auto px-6 lg:px-12 w-full pb-10">
            <div class="h-6 w-40 bg-white/30 rounded mb-3 animate-pulse"></div>
            <div class="h-12 w-72 bg-white/30 rounded animate-pulse"></div>
        </div>
    }
</section>

@* Main Content: Sidebar + Grid *@
<section class="py-16 bg-stone-50">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
        @if (category is not null || (!CategoryId.HasValue && products is not null))
        {
            <div class="flex flex-col lg:flex-row gap-12">

                @* Sidebar *@
                <div class="lg:w-56 flex-shrink-0">
                    @if (CategoryId.HasValue)
                    {
                        <CategorySidebar Category="category" />
                    }
                    else if (categories is not null)
                    {
                        <nav>
                            <h3 class="text-xs font-bold uppercase tracking-[0.2em] text-stone-400 mb-4">Browse by Category</h3>
                            <ul class="space-y-1">
                                <li>
                                    <span class="block px-3 py-2 text-sm font-medium text-primary border-l-2 border-primary">
                                        All
                                    </span>
                                </li>
                                @foreach (var cat in categories)
                                {
                                    <li>
                                        <a href="/collections/@cat.Id"
                                           class="block px-3 py-2 text-sm text-stone-600 hover:text-primary border-l-2 border-transparent hover:border-primary/50 transition-colors">
                                            @cat.Name
                                        </a>
                                    </li>
                                }
                            </ul>
                        </nav>
                    }
                </div>

                @* Product Grid + Banner *@
                <div class="flex-1 min-w-0">
                    @* Sort / Count header *@
                    <div class="flex items-center justify-between mb-8">
                        <p class="text-sm text-stone-500 font-light">
                            @if (products is not null)
                            {
                                <span>Showing <strong class="text-stone-800">@products.Count</strong> items</span>
                            }
                        </p>
                        <div class="flex items-center gap-2">
                            <label class="text-xs text-stone-400 uppercase tracking-widest">Sort</label>
                            <select class="text-sm text-stone-700 bg-transparent border-b border-stone-300 focus:outline-none focus:border-primary cursor-pointer py-1">
                                <option>Featured</option>
                                <option>Price: Low to High</option>
                                <option>Price: High to Low</option>
                                <option>Newest</option>
                            </select>
                        </div>
                    </div>

                    @if (products is not null)
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 md:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
                            @{ var productIndex = 0; }
                            @foreach (var product in products)
                            {
                                @* Subscription banner after first 3 products *@
                                @if (productIndex == 3)
                                {
                                    <div class="col-span-1 sm:col-span-2 lg:col-span-3 bg-gradient-to-r from-stone-800 to-stone-700 rounded-2xl p-8 flex flex-col md:flex-row items-center justify-between gap-6 my-4">
                                        <div>
                                            <p class="text-xs font-bold uppercase tracking-[0.2em] text-primary mb-2">The Bloom Letter</p>
                                            <h3 class="text-2xl font-display text-white mb-1">Stories of Flowers &amp; Feeling</h3>
                                            <p class="text-stone-400 text-sm font-light">Seasonal collections, care guides, and exclusive offers — delivered softly.</p>
                                        </div>
                                        <form class="flex gap-2 flex-shrink-0 w-full md:w-auto">
                                            <input type="email" placeholder="your@email.com"
                                                   class="flex-1 md:w-52 px-4 py-3 rounded-full text-sm bg-white/10 text-white placeholder-stone-400 border border-white/20 focus:outline-none focus:border-primary" />
                                            <button type="submit"
                                                    class="px-6 py-3 rounded-full bg-primary text-white text-sm font-bold hover:bg-primary-dark transition-colors flex-shrink-0">
                                                Subscribe
                                            </button>
                                        </form>
                                    </div>
                                }

                                @* Product Card *@
                                <a href="/product/@product.Id" class="group cursor-pointer">
                                    <div class="relative overflow-hidden rounded-xl mb-4 aspect-[3/4] bg-stone-100">
                                        <div class="absolute inset-0 bg-stone-900/0 group-hover:bg-stone-900/5 transition-colors duration-500 z-10"></div>
                                        <img src="@(product.ImageUrl ?? "https://lh3.googleusercontent.com/aida-public/AB6AXuDmzy6t1dSZcdLn3nH-K_eIQEQVM0tHSW8OtotNY-BrMMoVo5vmarWAAtGilqv7tz04b5E8bKzrgoRT4ZrPvSdP_jjm_fbHjQRxK5rUOae2DoUEmxyeelcBCahqkfJKoHi7OU2p7JgEuhXBa4cH_7MLmCQqvCIHhCIFzH2-lQa0maPmWUNegRLI5oq5D97_mCK_rOz9a2hLW8CFvfXefkcBzankUXgwkD_fpAfwIpdDGn337E6DdOccUrhX5o_iJenZfqNxXBfIfsQ")"
                                             alt="@product.Name"
                                             class="w-full h-full object-cover group-hover:scale-[1.03] transition-transform duration-700" />
                                    </div>
                                    <div class="flex flex-col">
                                        <h3 class="font-display text-xl text-stone-800 group-hover:text-primary transition-colors">@product.Name</h3>
                                        <p class="text-stone-500 text-sm font-light italic mb-2">@product.Description</p>
                                        <div class="flex items-center gap-2">
                                            <span class="text-base font-display text-stone-800">@product.Price.ToString("C")</span>
                                        </div>
                                    </div>
                                </a>

                                productIndex++;
                            }
                        </div>

                        @* Pagination *@
                        <div class="mt-16">
                            <Pagination CurrentPage="1" TotalPages="3" BaseUrl="@(CategoryId.HasValue ? $"/collections/{CategoryId}" : "/collections")" />
                        </div>
                    }
                    else
                    {
                        <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-x-6 gap-y-12">
                            @for (int i = 0; i < 6; i++)
                            {
                                <div class="animate-pulse">
                                    <div class="aspect-[3/4] bg-stone-200 rounded-xl mb-4"></div>
                                    <div class="h-5 bg-stone-200 rounded w-3/4 mb-2"></div>
                                    <div class="h-4 bg-stone-200 rounded w-1/2 mb-2"></div>
                                    <div class="h-4 bg-stone-200 rounded w-1/4"></div>
                                </div>
                            }
                        </div>
                    }
                </div>
            </div>
        }
    </div>
</section>

@* Floral Care Guide *@
<section class="py-20 bg-white">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
        <div class="text-center mb-12">
            <h2 class="text-3xl md:text-4xl font-display text-stone-800 mb-3">Care Guide</h2>
            <p class="text-stone-500 font-light max-w-xl mx-auto">Every arrangement is a living expression. Here's how to help yours flourish.</p>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
            @* Care tile 1 *@
            <div class="relative rounded-2xl overflow-hidden h-64 group">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuCXOMgfLAN299HXnFTq5MqxB_JFn9gIPvH2gwpSxwJ1jFNAnV7L4a10lo-nKWnD77PQUZ2JjaMh05XAhwY2a8uGuG9ntK79BgnoaQ7hQzdApuMtvig_v0H-4_7bNQ2eIRmW1qk1B5iJycrwhQlDg1A-p6ivT99YOhCNHkTwWS-VakfewSowim9jinZdq9JVt_V-EBoefcoBGuJBCg5Y5uXdSP4socWkyXbGmwTGjZPvwxgpAR2pGDUsdntMt0HHpPcxNzozVtyz5dI"
                     alt="Fresh flower care"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-stone-900/70 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-6">
                    <h3 class="font-display text-xl text-white mb-1">Fresh Arrangements</h3>
                    <p class="text-white/75 text-sm font-light">Change water every two days. Trim stems at a 45° angle. Keep away from direct sunlight.</p>
                </div>
            </div>
            @* Care tile 2 *@
            <div class="relative rounded-2xl overflow-hidden h-64 group">
                <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuDmzy6t1dSZcdLn3nH-K_eIQEQVM0tHSW8OtotNY-BrMMoVo5vmarWAAtGilqv7tz04b5E8bKzrgoRT4ZrPvSdP_jjm_fbHjQRxK5rUOae2DoUEmxyeelcBCahqkfJKoHi7OU2p7JgEuhXBa4cH_7MLmCQqvCIHhCIFzH2-lQa0maPmWUNegRLI5oq5D97_mCK_rOz9a2hLW8CFvfXefkcBzankUXgwkD_fpAfwIpdDGn337E6DdOccUrhX5o_iJenZfqNxXBfIfsQ"
                     alt="Dried flower care"
                     class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700" />
                <div class="absolute inset-0 bg-gradient-to-t from-stone-900/70 to-transparent"></div>
                <div class="absolute bottom-0 left-0 p-6">
                    <h3 class="font-display text-xl text-white mb-1">Dried & Preserved</h3>
                    <p class="text-white/75 text-sm font-light">Keep in a dry space away from humidity. Dust gently. Avoid prolonged direct sunlight to preserve colour.</p>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [Parameter]
    public int? CategoryId { get; set; }

    private Category? category;
    private List<Category>? categories;
    private List<Product>? products;

    protected override async Task OnInitializedAsync()
    {
        if (CategoryId.HasValue)
        {
            category = await ProductService.GetCategoryAsync(CategoryId.Value);
            products = await ProductService.GetProductsByCategoryAsync(CategoryId.Value);
        }
        else
        {
            products = await ProductService.GetProductsAsync();
            categories = await ProductService.GetCategoriesAsync();
        }
    }
}
