@page "/checkout"
@rendermode InteractiveServer
@attribute [Authorize]
@using Microsoft.AspNetCore.Identity
@using WithLove.Data.Models
@using WithLove.Workflows.Activities
@using ZiggyCreatures.Caching.Fusion
@inject ICartService CartService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject IJSRuntime JS
@inject Stripe.StripeClient StripeClient
@inject IConfiguration Configuration
@inject AnonymousCartSession AnonSession
@inject UserManager<ShopUser> UserManager
@inject ILoyaltyService LoyaltyService
@inject IFusionCache FusionCache
@inject WithLove.Web.Services.Instrumentation Instrumentation
@implements IAsyncDisposable

<PageTitle>Checkout | With Love</PageTitle>

<div class="bg-white border-b border-stone-200">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-5 flex items-center justify-between">
        <a href="/" class="font-display text-2xl text-stone-800">With Love</a>
        <div class="flex items-center gap-2 text-stone-400 text-sm">
            <span class="material-symbols-outlined text-base">lock</span>
            <span>Secure Checkout</span>
        </div>
    </div>
</div>

<section class="py-12 md:py-16 bg-stone-50 min-h-[80vh]">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">

        <div class="mb-10">
            <h1 class="font-display text-3xl md:text-4xl text-stone-800">Finalize Your Gift</h1>
            <p class="text-stone-500 font-light mt-2">Complete your order with care and intention.</p>
        </div>

        <div class="grid lg:grid-cols-3 gap-10 xl:gap-16 items-start">

            <div class="lg:col-span-2">
                <EditForm Model="checkoutModel" OnValidSubmit="HandleValidSubmit" FormName="checkout">
                    <DataAnnotationsValidator />

                    @if (_paymentInitiated)
                    {
                        <div class="bg-white rounded-2xl border border-stone-200 p-6 md:p-8 mb-6">
                            <CheckoutStepHeader StepNumber="1" Title="Delivery Recipient" />

                            <div class="relative min-h-[80px]">
                                @if (!_stripeReady)
                                {
                                    <div class="absolute inset-0 z-10 bg-white/80 rounded-xl flex items-center justify-center gap-2 text-stone-400 text-sm">
                                        <span class="material-symbols-outlined text-base animate-spin">progress_activity</span>
                                        <span class="font-light">Loading address form...</span>
                                    </div>
                                }
                                <div id="shipping-address-element" class="min-h-[80px]"></div>
                            </div>
                        </div>
                    }

                    <div class="bg-white rounded-2xl border border-stone-200 p-6 md:p-8 mb-6">
                        <CheckoutStepHeader StepNumber="2" Title="Your Message" />

                        <div class="mb-5">
                            <label class="block text-xs font-bold uppercase tracking-[0.12em] text-stone-400 mb-2" for="recipientFirstName">Recipient's First Name</label>
                            <InputText id="recipientFirstName"
                                       @bind-Value="checkoutModel.RecipientFirstName"
                                       placeholder="Elara"
                                       class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-xl text-stone-800 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-stone-300" />
                            <p class="text-xs text-stone-400 font-light mt-1">Used for the "Dear..." greeting on your note card.</p>
                        </div>

                        <div class="mb-5">
                            <label class="block text-xs font-bold uppercase tracking-[0.12em] text-stone-400 mb-2" for="message">Personal Note</label>
                            <InputTextArea id="message"
                                           @bind-Value="checkoutModel.Message"
                                           rows="4"
                                           placeholder="Write something from the heart..."
                                           class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-xl text-stone-700 font-handwriting text-base focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-stone-300 placeholder:font-body resize-none" />
                        </div>

                    </div>

                    @if (!_paymentInitiated)
                    {
                        <div class="flex justify-end mb-6">
                            <button type="button" @onclick="ProceedToPaymentAsync"
                                    disabled="@(_stripeLoading)"
                                    class="px-8 py-3 bg-stone-800 text-white rounded-full font-bold text-sm uppercase tracking-wider hover:bg-primary transition-all disabled:opacity-60 flex items-center gap-2">
                                @if (_stripeLoading)
                                {
                                    <span class="material-symbols-outlined text-base animate-spin">progress_activity</span>
                                    <span>Setting up payment...</span>
                                }
                                else
                                {
                                    <span>Proceed to Payment</span>
                                    <span class="material-symbols-outlined text-base">arrow_forward</span>
                                }
                            </button>
                        </div>
                    }

                    @if (_paymentInitiated)
                    {
                        <div class="bg-white rounded-2xl border border-stone-200 p-6 md:p-8 mb-8">
                            <CheckoutStepHeader StepNumber="3" Title="Secure Payment" />

                            <div class="mb-6">
                                <label class="block text-xs font-bold uppercase tracking-[0.12em] text-stone-400 mb-2" for="billingEmail">Billing Email</label>
                                <InputText id="billingEmail"
                                           @bind-Value="checkoutModel.BillingEmail"
                                           type="email"
                                           placeholder="your@email.com"
                                           readonly
                                           class="w-full px-4 py-3 bg-stone-50 border border-stone-200 rounded-xl text-stone-800 text-sm focus:outline-none focus:border-primary focus:ring-2 focus:ring-primary/10 transition-all placeholder:text-stone-300" />
                                <ValidationMessage For="@(() => checkoutModel.BillingEmail)" class="text-xs text-red-500 mt-1" />
                            </div>

                            <div class="relative mb-5 min-h-[80px]">
                                @if (!_stripeReady)
                                {
                                    <div class="absolute inset-0 z-10 bg-white/80 rounded-xl flex items-center justify-center gap-2 text-stone-400 text-sm">
                                        <span class="material-symbols-outlined text-base animate-spin">progress_activity</span>
                                        <span class="font-light">Loading secure payment...</span>
                                    </div>
                                }
                                <div id="payment-element" class="bg-stone-50 border border-stone-200 rounded-xl p-3 min-h-[80px]"></div>
                            </div>

                            <div class="flex items-center gap-2 mb-6 text-stone-400">
                                <span class="material-symbols-outlined text-sm">lock</span>
                                <p class="text-xs font-light">Your payment information is encrypted and never stored on our servers.</p>
                            </div>

                            <button type="submit"
                                    disabled="@isSubmitting"
                                    class="w-full bg-stone-800 text-white py-4 rounded-full font-bold text-sm uppercase tracking-wider hover:bg-primary transition-all shadow-lg shadow-stone-300/50 disabled:opacity-60 disabled:cursor-not-allowed flex items-center justify-center gap-2">
                                @if (isSubmitting)
                                {
                                    <span class="material-symbols-outlined text-base animate-spin">progress_activity</span>
                                    <span>Processing...</span>
                                }
                                else
                                {
                                    <span class="material-symbols-outlined text-base">favorite</span>
                                    <span>Complete Purchase</span>
                                }
                            </button>

                            @if (!string.IsNullOrEmpty(errorMessage))
                            {
                                <p class="text-sm text-red-500 text-center mt-4">@errorMessage</p>
                            }
                        </div>
                    }

                    @if (!_paymentInitiated && !string.IsNullOrEmpty(errorMessage))
                    {
                        <p class="text-sm text-red-500 text-center mt-4">@errorMessage</p>
                    }

                </EditForm>
            </div>

            <div class="lg:col-span-1 space-y-6">

                <PersonalNotePreview Message="@checkoutModel.Message"
                                     RecipientName="@checkoutModel.RecipientFirstName" />

                @if ((_loyaltyProfile?.Balance ?? 0) > 0 && !_paymentInitiated)
                {
                    <div class="bg-white rounded-2xl border border-stone-200 p-5">
                        <div class="flex items-center gap-2 mb-4">
                            <span class="material-symbols-outlined text-primary">favorite</span>
                            <h3 class="font-display text-stone-800">Love Tokens</h3>
                        </div>
                        <p class="text-xs text-stone-500 mb-3">You have <strong>@_loyaltyProfile!.Balance pts</strong> available. 100 pts = $1 off.</p>
                        <div class="flex gap-2">
                            <input type="number"
                                   class="flex-1 px-3 py-2 bg-stone-50 border border-stone-200 rounded-xl text-sm text-stone-800 focus:outline-none focus:border-primary"
                                   min="100" step="100" max="@GetMaxRedeemablePoints()"
                                   placeholder="e.g. 100" @bind="_pointsToRedeem" />
                            <button type="button" @onclick="ApplyTokens"
                                    class="px-4 py-2 bg-primary text-white rounded-xl text-sm font-medium hover:bg-primary-dark transition-colors">
                                Apply
                            </button>
                        </div>
                        @if (_appliedDiscount > 0)
                        {
                            <p class="text-xs text-green-600 mt-2 font-medium">&#10003; @_pointsToRedeem pts will be redeemed for @_appliedDiscount.ToString("C") off</p>
                        }
                    </div>
                }

                <CheckoutSummary Items="CartService.Items"
                                 Subtotal="CartService.Subtotal"
                                 EnhancementsTotal="CartService.EnhancementsTotal"
                                 AvailablePoints="@(_loyaltyProfile?.Balance ?? 0)"
                                 PointsDiscount="@_appliedDiscount" />

                <div class="bg-white rounded-2xl border border-stone-200 p-5 space-y-4">
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-lg text-sage-green">verified_user</span>
                        <div>
                            <p class="text-xs font-bold text-stone-700 uppercase tracking-wider">SSL Secured</p>
                            <p class="text-xs text-stone-400 font-light">256-bit encryption</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-lg text-sage-green">local_shipping</span>
                        <div>
                            <p class="text-xs font-bold text-stone-700 uppercase tracking-wider">Free Shipping</p>
                            <p class="text-xs text-stone-400 font-light">On all orders over $75</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-3">
                        <span class="material-symbols-outlined text-lg text-sage-green">autorenew</span>
                        <div>
                            <p class="text-xs font-bold text-stone-700 uppercase tracking-wider">Easy Returns</p>
                            <p class="text-xs text-stone-400 font-light">30-day hassle-free returns</p>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</section>

@code {
    [SupplyParameterFromForm]
    private CheckoutModel checkoutModel { get; set; } = default!;

    private bool isSubmitting;
    private bool stripeInitialized;
    private string? errorMessage;
    private string? stripeCustomerId;
    private string? stripeSessionId;

    private bool _paymentInitiated;
    private bool _stripeLoading;
    private bool _stripeReady;

    private LoyaltyProfile? _loyaltyProfile;
    private int _pointsToRedeem;
    private decimal _appliedDiscount;
    private string? _redemptionId;

    private string? _currentUserId;

    protected override async Task OnInitializedAsync()
    {
        checkoutModel ??= new CheckoutModel();

        await CartService.InitializeFromAuthAsync(AuthStateProvider, AnonSession);

        var auth = await AuthStateProvider.GetAuthenticationStateAsync();
        var user = auth.User.Identity?.IsAuthenticated == true
            ? await UserManager.GetUserAsync(auth.User)
            : null;
        stripeCustomerId = user?.StripeCustomerId is { Length: > 0 } id ? id : null;

        if (user is not null && string.IsNullOrEmpty(checkoutModel.BillingEmail))
        {
            checkoutModel.BillingEmail = user.Email ?? string.Empty;
        }

        if (!CartService.Items.Any())
        {
            Navigation.NavigateTo("/cart");
        }

        _currentUserId = auth.User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value;
        if (_currentUserId is not null)
        {
            try
            {
                _loyaltyProfile = await LoyaltyService.GetLoyaltyProfileAsync(_currentUserId);
            }
            catch
            {
                _loyaltyProfile = null;
            }
        }
    }

    private void ApplyTokens()
    {
        var maxRedeemable = GetMaxRedeemablePoints();

        if (_pointsToRedeem < 100 || _pointsToRedeem > maxRedeemable || _pointsToRedeem % 100 != 0)
        {
            errorMessage = "Enter a valid amount in multiples of 100.";
            return;
        }
        _appliedDiscount = _pointsToRedeem / 100m;
        errorMessage = null;
    }

    private int GetMaxRedeemablePoints()
    {
        var maxByOrder = Math.Floor(Math.Max(0m, CartService.Total - 0.50m)) * 100;
        return (int)Math.Min(_loyaltyProfile?.Balance ?? 0, maxByOrder);
    }

    private async Task ProceedToPaymentAsync()
    {
        _paymentInitiated = true;
        _stripeLoading = true;
        errorMessage = null;
        _redemptionId = null;
        _appliedDiscount = 0;
        StateHasChanged();

        if (_pointsToRedeem > 0)
        {
            var maxRedeemable = GetMaxRedeemablePoints();
            if (_currentUserId is null ||
                _pointsToRedeem < 100 ||
                _pointsToRedeem > maxRedeemable ||
                _pointsToRedeem % 100 != 0)
            {
                errorMessage = "Enter a valid Love Tokens amount before proceeding.";
                _paymentInitiated = false;
                _stripeLoading = false;
                StateHasChanged();
                return;
            }

            try
            {
                var reservation = await LoyaltyService.ReservePointsAsync(_currentUserId, _pointsToRedeem);
                _redemptionId = reservation.RedemptionId;
                _appliedDiscount = reservation.DiscountAmount;
            }
            catch
            {
                errorMessage = "Unable to apply Love Tokens. Proceeding without discount.";
                _pointsToRedeem = 0;
                _appliedDiscount = 0;
            }
        }

        Instrumentation.CartItemsAtCheckout.Record(CartService.ItemCount);

        try
        {
            var lineItems = CartService.Items.Select(item => new Stripe.Checkout.SessionLineItemOptions
            {
                Price = item.StripePriceId,
                Quantity = item.Quantity
            }).ToList();

            foreach (var enhancement in CartService.Enhancements.Where(e => e.IsSelected))
            {
                lineItems.Add(new Stripe.Checkout.SessionLineItemOptions
                {
                    PriceData = new Stripe.Checkout.SessionLineItemPriceDataOptions
                    {
                        Currency = "usd",
                        UnitAmount = (long)(enhancement.Price * 100),
                        ProductData = new Stripe.Checkout.SessionLineItemPriceDataProductDataOptions
                        {
                            Name = enhancement.Name
                        }
                    },
                    Quantity = 1
                });
            }

            string? couponId = null;
            if (_appliedDiscount > 0)
            {
                var coupon = await StripeClient.V1.Coupons.CreateAsync(new Stripe.CouponCreateOptions
                {
                    AmountOff = (long)(_appliedDiscount * 100),
                    Currency = "usd",
                    Duration = "once",
                    Name = $"Love Tokens ({_pointsToRedeem} pts)"
                });
                couponId = coupon.Id;
            }

            var sessionOptions = new Stripe.Checkout.SessionCreateOptions
            {
                UiMode = "custom",
                Mode = "payment",
                LineItems = lineItems,
                ReturnUrl = $"{Navigation.BaseUri}order-confirmation?session_id={{CHECKOUT_SESSION_ID}}",
                Customer = stripeCustomerId,
                ShippingAddressCollection = new() { AllowedCountries = ["US", "CA", "GB", "AU"] },
                Metadata = new Dictionary<string, string>()
            };

            if (_currentUserId is not null)
                sessionOptions.Metadata["userId"] = _currentUserId;
            if (_redemptionId is not null)
                sessionOptions.Metadata["redemptionId"] = _redemptionId;

            // Stripe disallows promotion codes when a fixed coupon is attached.
            if (couponId is not null)
            {
                sessionOptions.AllowPromotionCodes = null;
                sessionOptions.Discounts = [new Stripe.Checkout.SessionDiscountOptions { Coupon = couponId }];
            }
            else
            {
                sessionOptions.AllowPromotionCodes = true;
            }

            await CreateAndMountStripeSession(sessionOptions);
        }
        catch (Exception)
        {
            if (_redemptionId is not null && _currentUserId is not null)
            {
                try
                {
                    await LoyaltyService.CancelRedemptionAsync(_currentUserId, _redemptionId);
                }
                catch
                {
                    // Expiry restores the balance if best-effort cancel fails.
                }
                _redemptionId = null;
                _appliedDiscount = 0;
            }
            _paymentInitiated = false;
            errorMessage = "Unable to initialize payment. Please try again.";
        }
        finally
        {
            _stripeLoading = false;
            StateHasChanged();
        }
    }

    private async Task CreateAndMountStripeSession(Stripe.Checkout.SessionCreateOptions sessionOptions)
    {
        var session = await StripeClient.V1.Checkout.Sessions.CreateAsync(sessionOptions);
        stripeSessionId = session.Id;

        // Cache the confirmationNumber → sessionId mapping so the order detail page
        // can resolve it without scanning all sessions. Written before payment completes
        // (session is pending); GetOrderAsync validates PaymentStatus == "paid" before returning data.
        // _currentUserId is set during OnInitializedAsync via AuthStateProvider.
        // Blazor components have no implicit User property — use the existing field.
        // Checkout.razor is [Authorize] so _currentUserId is never null, but check defensively.
        var confirmationNumber = OrderInfo.GenerateConfirmationNumber(session.Id);
        if (_currentUserId is not null)
        {
            await FusionCache.SetAsync(
                $"order:confirm:{_currentUserId}:{confirmationNumber}",
                session.Id,
                new FusionCacheEntryOptions { Duration = TimeSpan.FromDays(365) });
        }

        var publicKey = Configuration["Stripe:Default:PublicKey"];

        await JS.InvokeVoidAsync("StripeCheckout.init", publicKey, session.ClientSecret);
        _stripeReady = true;
        stripeInitialized = true;
        StateHasChanged();
    }

    private async Task HandleValidSubmit()
    {
        if (!_stripeReady)
        {
            errorMessage = "Payment form is still loading. Please wait.";
            return;
        }

        isSubmitting = true;
        errorMessage = null;
        StateHasChanged();

        try
        {
            if (!string.IsNullOrEmpty(stripeSessionId))
            {
                var msg = checkoutModel.Message ?? "";
                var recipientName = checkoutModel.RecipientFirstName ?? "";
                await StripeClient.V1.Checkout.Sessions.UpdateAsync(stripeSessionId,
                    new Stripe.Checkout.SessionUpdateOptions
                    {
                        Metadata = new Dictionary<string, string>
                        {
                            ["gift_message"] = msg.Length > 500 ? msg[..500] : msg,
                            ["recipient_first_name"] = recipientName.Length > 100 ? recipientName[..100] : recipientName
                        }
                    });
            }

            var result = await JS.InvokeAsync<StripeConfirmResult>("StripeCheckout.confirm");
            if (!result.Success)
            {
                errorMessage = result.Error ?? "Payment failed. Please try again.";
                isSubmitting = false;
            }
        }
        catch (TaskCanceledException)
        {
            // Stripe redirected to return_url and closed the circuit.
        }
        catch (JSDisconnectedException)
        {
            // Circuit closed during browser redirect.
        }
        catch (Exception)
        {
            errorMessage = "Something went wrong processing your payment. Please try again.";
            isSubmitting = false;
        }
    }

    public async ValueTask DisposeAsync()
    {
        if (!stripeInitialized)
            return;

        try
        {
            await JS.InvokeVoidAsync("StripeCheckout.destroy");
        }
        catch (JSDisconnectedException)
        {
            // Circuit already closed.
        }
        catch (InvalidOperationException)
        {
            // JS runtime is unavailable during prerender disposal.
        }
    }

    private record StripeConfirmResult(bool Success, string? Error);
}
