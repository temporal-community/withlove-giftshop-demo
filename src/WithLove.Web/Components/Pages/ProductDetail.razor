@page "/product/{ProductId:int}"
@attribute [StreamRendering]
@inject IProductService ProductService

<PageTitle>@(product?.Name ?? "Product") | With Love</PageTitle>

@if (product is not null)
{
    @* Breadcrumb *@
    <div class="bg-stone-50 border-b border-stone-200">
        <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-4">
            <Breadcrumb Items="@(new List<BreadcrumbItem> {
                new("Home", "/"),
                new("Collection", $"/collections/{product.CategoryId}"), 
                new(product.Name, null)
            })" />
        </div>
    </div>

    @* Product Detail Main *@
    <section class="py-12 md:py-20 bg-stone-50">
        <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
            <div class="grid lg:grid-cols-2 gap-12 xl:gap-20 items-start">

                @* Interactive section: gallery + add to cart *@
                <ProductInteractions Product="product" />

                @* Static product info *@
                <div class="space-y-8 lg:pt-4">
                    @* Sub-collection badge *@
                    @if (!string.IsNullOrEmpty(product.SubCategory))
                    {
                        <span class="inline-block text-xs font-bold uppercase tracking-[0.2em] text-earth-brown border-b border-earth-brown/30 pb-0.5">
                            @product.SubCategory
                        </span>
                    }

                    @* Name *@
                    <div>
                        <h1 class="text-4xl md:text-5xl font-display text-stone-800 leading-tight">@product.Name</h1>
                    </div>

                    @* Price *@
                    <div class="flex items-baseline gap-3">
                        <span class="text-3xl font-display text-stone-800">@product.Price.ToString("C")</span>
                    </div>

                    @* Divider *@
                    <div class="w-full h-px bg-stone-200"></div>

                    @* Description *@
                    <p class="text-stone-600 font-light leading-relaxed text-lg">@product.Description</p>

                    @* Materials *@
                    @if (product.Materials.Any())
                    {
                        <div>
                            <h3 class="text-xs font-bold uppercase tracking-[0.15em] text-stone-400 mb-4">Composition</h3>
                            <div class="grid grid-cols-2 gap-3">
                                @foreach (var material in product.Materials)
                                {
                                    <div class="flex items-center gap-3 p-3 bg-white rounded-xl border border-stone-100">
                                        <span class="material-symbols-outlined text-xl text-earth-brown">@material.Icon</span>
                                        <span class="text-sm text-stone-700 font-medium">@material.Name</span>
                                    </div>
                                }
                            </div>
                        </div>
                    }
                    do
                    @* Trust badges *@
                    <div class="flex items-center gap-6 pt-2">
                        <div class="flex items-center gap-2 text-stone-500 text-sm">
                            <span class="material-symbols-outlined text-lg text-sage-green">local_shipping</span>
                            <span>Free Shipping</span>
                        </div>
                        <div class="flex items-center gap-2 text-stone-500 text-sm">
                            <span class="material-symbols-outlined text-lg text-sage-green">verified</span>
                            <span>Authenticity Guarantee</span>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>

    @* Story Section *@
    @if (!string.IsNullOrEmpty(product.StoryTitle))
    {
        <section class="py-20 bg-white">
            <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
                <div class="max-w-3xl mx-auto text-center mb-14">
                    <span class="text-xs font-bold uppercase tracking-[0.2em] text-earth-brown">The Story</span>
                    <h2 class="text-3xl md:text-4xl font-display text-stone-800 mt-3 mb-4">@product.StoryTitle</h2>
                    @if (!string.IsNullOrEmpty(product.StoryDescription))
                    {
                        <p class="text-stone-500 font-light leading-relaxed text-lg">@product.StoryDescription</p>
                    }
                </div>
                @if (product.Features.Any())
                {
                    <div class="grid md:grid-cols-3 gap-8">
                        @foreach (var feature in product.Features)
                        {
                            <div class="text-center p-8 bg-stone-50 rounded-2xl">
                                <span class="material-symbols-outlined text-3xl text-primary mb-4 block">@feature.Icon</span>
                                <h3 class="font-display text-xl text-stone-800 mb-2">@feature.Title</h3>
                                <p class="text-stone-500 text-sm font-light leading-relaxed">@feature.Description</p>
                            </div>
                        }
                    </div>
                }
            </div>
        </section>
    }

    @* Recommendations *@
    @if (recommendations is not null && recommendations.Any())
    {
        <section class="py-20 bg-stone-50">
            <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-display text-stone-800 mb-2">Curated for You</h2>
                    <p class="text-stone-500 font-light">You might also love these</p>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    @foreach (var rec in recommendations)
                    {
                        <ProductCardRecommendation Product="rec" />
                    }
                </div>
            </div>
        </section>
    }
    else if (recommendations is null)
    {
        <section class="py-20 bg-stone-50">
            <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
                <div class="text-center mb-12">
                    <h2 class="text-3xl font-display text-stone-800 mb-2">Curated for You</h2>
                </div>
                <div class="grid grid-cols-2 md:grid-cols-4 gap-6">
                    @for (int i = 0; i < 4; i++)
                    {
                        <div class="animate-pulse">
                            <div class="aspect-square bg-stone-200 rounded-xl mb-3"></div>
                            <div class="h-4 bg-stone-200 rounded w-3/4 mb-2"></div>
                            <div class="h-4 bg-stone-200 rounded w-1/3"></div>
                        </div>
                    }
                </div>
            </div>
        </section>
    }
}
else
{
    @* Loading skeleton *@
    <div class="py-20 bg-stone-50">
        <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
            <div class="grid lg:grid-cols-2 gap-12 items-start animate-pulse">
                <div class="aspect-square bg-stone-200 rounded-3xl"></div>
                <div class="space-y-6">
                    <div class="h-4 bg-stone-200 rounded w-1/4"></div>
                    <div class="h-10 bg-stone-200 rounded w-3/4"></div>
                    <div class="h-8 bg-stone-200 rounded w-1/4"></div>
                    <div class="h-px bg-stone-200"></div>
                    <div class="space-y-2">
                        <div class="h-4 bg-stone-200 rounded"></div>
                        <div class="h-4 bg-stone-200 rounded"></div>
                        <div class="h-4 bg-stone-200 rounded w-5/6"></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter]
    public int ProductId { get; set; }

    private Product? product;
    private List<Product>? recommendations;

    protected override async Task OnInitializedAsync()
    {
        product = await ProductService.GetProductAsync(ProductId);
        if (product is not null)
        {
            recommendations = await ProductService.GetRecommendationsAsync(ProductId);
        }
    }
}
