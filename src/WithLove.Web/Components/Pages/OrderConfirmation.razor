@page "/order-confirmation"
@layout LoginLayout
@rendermode InteractiveServer
@inject ICartService CartService
@inject NavigationManager Navigation
@inject AuthenticationStateProvider AuthStateProvider
@inject Stripe.StripeClient StripeClient
@inject AnonymousCartSession AnonSession
@using Microsoft.AspNetCore.WebUtilities
@using WithLove.Workflows.Activities

<PageTitle>Order Confirmed | With Love</PageTitle>

@* Custom header — always visible *@
<header class="fixed top-0 w-full z-50 bg-stone-50/90 backdrop-blur-md border-b border-stone-100 transition-all duration-300">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
        <div class="flex items-center justify-between h-20">
            <div class="flex-shrink-0">
                <a class="font-display text-2xl tracking-widest text-stone-800 flex items-center gap-2 group" href="/">
                    <span class="relative">
                        <span class="material-symbols-outlined text-primary font-light text-xl group-hover:scale-110 transition-transform duration-500">spa</span>
                    </span>
                    <span>with love</span>
                </a>
            </div>
            <nav class="hidden md:flex space-x-12">
                <div class="text-[10px] uppercase tracking-[0.4em] text-earth-brown font-semibold">Order Confirmed</div>
            </nav>
            <div class="flex items-center">
                <a class="text-stone-600 hover:text-primary transition-colors flex items-center gap-2 text-xs uppercase tracking-widest" href="/">
                    <span class="material-symbols-outlined font-light text-lg">home</span>
                    <span class="hidden sm:inline">Back to Shop</span>
                </a>
            </div>
        </div>
    </div>
</header>

@* Decorative blobs *@
<div class="fixed top-40 left-0 w-96 h-96 bg-primary/5 rounded-full mix-blend-multiply filter blur-3xl opacity-60 pointer-events-none -translate-x-1/2"></div>
<div class="fixed bottom-0 right-0 w-[500px] h-[500px] bg-sage-green/5 rounded-[64%_36%_28%_72%/68%_38%_62%_32%] mix-blend-multiply filter blur-3xl opacity-50 pointer-events-none translate-x-1/3 translate-y-1/3"></div>

<main class="pt-28 pb-24 min-h-screen relative">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10">

        @if (isLoading)
        {
            <div class="flex items-center justify-center gap-2 py-24 text-stone-400">
                <span class="material-symbols-outlined text-2xl animate-spin">progress_activity</span>
                <span class="text-lg font-light">Verifying your order...</span>
            </div>
        }
        else if (paymentVerified)
        {
            <div class="grid grid-cols-1 lg:grid-cols-12 gap-16 items-start">

                @* Left column — Gift Contents, Delivery, Payment, Note *@
                <div class="lg:col-span-7 space-y-12 order-2 lg:order-1">

                    @* Gift Contents *@
                    <section class="space-y-8">
                        <div class="flex items-center gap-4 pb-4 border-b border-stone-200">
                            <h2 class="text-xl font-display text-stone-800 tracking-wide uppercase">Gift Contents</h2>
                        </div>
                        <div class="space-y-6">
                            @foreach (var item in lineItems)
                            {
                                <div class="flex items-center gap-6">
                                    <div class="w-20 h-20 bg-white rounded-lg border border-stone-200 flex items-center justify-center overflow-hidden flex-shrink-0">
                                        @if (!string.IsNullOrEmpty(item.ImageUrl))
                                        {
                                            <img src="@item.ImageUrl" alt="@item.Name" class="w-full h-full object-cover" />
                                        }
                                        else
                                        {
                                            <span class="material-symbols-outlined text-stone-300">image</span>
                                        }
                                    </div>
                                    <div class="flex-1">
                                        <h4 class="text-base font-medium text-stone-800 font-display uppercase tracking-wider">@item.Name</h4>
                                        @if (!string.IsNullOrEmpty(item.Description))
                                        {
                                            <p class="text-sm text-stone-500 italic">@item.Description</p>
                                        }
                                        @if (item.Quantity > 1)
                                        {
                                            <p class="text-xs text-stone-400">Qty: @item.Quantity</p>
                                        }
                                    </div>
                                    <span class="text-stone-800 font-medium">@item.Amount.ToString("C")</span>
                                </div>
                            }
                        </div>
                    </section>

                    @* Delivery Address + Payment Summary *@
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-12 pt-8">
                        @if (!string.IsNullOrEmpty(recipientName))
                        {
                            <section class="space-y-6">
                                <div class="flex items-center gap-3 pb-3 border-b border-stone-200/60">
                                    <span class="material-symbols-outlined text-primary text-xl">local_shipping</span>
                                    <h3 class="text-xs font-display text-stone-800 tracking-[0.2em] uppercase">Delivery Address</h3>
                                </div>
                                <div class="text-sm text-stone-600 leading-relaxed font-light">
                                    <p class="font-bold text-stone-800 mb-1">@recipientName</p>
                                    @if (!string.IsNullOrEmpty(streetAddress))
                                    {
                                        <p>@streetAddress</p>
                                    }
                                    @if (!string.IsNullOrEmpty(cityPostal))
                                    {
                                        <p>@cityPostal</p>
                                    }
                                    @if (!string.IsNullOrEmpty(state))
                                    {
                                        <p>@state</p>
                                    }
                                    @if (!string.IsNullOrEmpty(country))
                                    {
                                        <p>@country</p>
                                    }
                                </div>
                            </section>
                        }

                        <section class="space-y-6">
                            <div class="flex items-center gap-3 pb-3 border-b border-stone-200/60">
                                <span class="material-symbols-outlined text-primary text-xl">payments</span>
                                <h3 class="text-xs font-display text-stone-800 tracking-[0.2em] uppercase">Payment Summary</h3>
                            </div>
                            <div class="text-sm text-stone-600 space-y-2">
                                <div class="flex justify-between">
                                    <span class="font-light">Method:</span>
                                    <span class="text-stone-800 font-medium flex items-center gap-1">@paymentMethodDisplay</span>
                                </div>
                                <div class="flex justify-between pt-2 mt-2 border-t border-stone-100">
                                    <span class="font-display uppercase tracking-wider text-xs">Total Paid</span>
                                    <span class="font-display text-lg text-stone-800">@totalPaid.ToString("C")</span>
                                </div>
                            </div>
                        </section>
                    </div>

                    @* Included Note *@
                    @if (giftMessage is not null)
                    {
                        <section class="pt-8">
                            <div class="bg-stone-100/30 border border-stone-200/50 p-8 rounded-2xl relative">
                                <span class="absolute top-6 right-8 text-primary/10 material-symbols-outlined text-5xl">format_quote</span>
                                <h3 class="text-[10px] uppercase tracking-widest text-stone-400 font-bold mb-4">Included Note</h3>
                                <p class="font-display text-stone-700 text-lg leading-relaxed italic">
                                    "@giftMessage"
                                </p>
                            </div>
                        </section>
                    }
                </div>

                @* Right column — Confirmation card *@
                <div class="lg:col-span-5 order-1 lg:order-2">
                    <div class="bg-white border border-stone-200 p-10 lg:p-12 rounded-2xl text-center space-y-8 shadow-sm relative overflow-hidden">
                        <div class="absolute top-0 left-0 w-full h-1.5 bg-primary"></div>

                        <div class="flex justify-center">
                            <div class="w-20 h-20 bg-stone-50 rounded-full flex items-center justify-center border border-stone-100">
                                <span class="material-symbols-outlined text-sage-green text-4xl">check_circle</span>
                            </div>
                        </div>

                        <div class="space-y-4">
                            <h1 class="text-3xl font-display text-stone-800 tracking-wide">Thank You</h1>
                            <p class="text-stone-500 font-light max-w-xs mx-auto leading-relaxed">
                                Your gift order has been placed and we're preparing it with the utmost care.
                            </p>
                        </div>

                        <div class="py-6 border-y border-stone-100">
                            <span class="text-[10px] uppercase tracking-widest text-stone-400 font-bold block mb-1">Confirmation Number</span>
                            <span class="text-xl font-display text-earth-brown tracking-widest">@confirmationNumber</span>
                        </div>

                        <div class="space-y-4">
                            @if (receiptUrl is not null)
                            {
                                <a href="@receiptUrl" target="_blank" rel="noopener noreferrer"
                                   class="w-full bg-stone-800 text-stone-50 py-4 rounded-lg font-display uppercase tracking-widest hover:bg-stone-700 transition-all duration-300 flex items-center justify-center gap-2 group">
                                    <span class="material-symbols-outlined text-sm font-light">print</span>
                                    Print Receipt
                                </a>
                            }
                            <a class="block w-full border border-stone-200 text-stone-600 py-4 rounded-lg font-display uppercase tracking-widest hover:bg-stone-50 transition-all duration-300 text-sm"
                               href="/account/orders">
                                View Order History
                            </a>
                        </div>

                        @if (!string.IsNullOrEmpty(customerEmail))
                        {
                            <div class="pt-4">
                                <p class="text-[11px] text-stone-400 leading-relaxed font-light">
                                    A confirmation email has been sent to <br />
                                    <span class="font-medium text-stone-600">@customerEmail</span>
                                </p>
                            </div>
                        }
                    </div>

                    @* Quick-link cards *@
                    <div class="mt-8 grid grid-cols-2 gap-4">
                        <a href="/contact" class="bg-white/50 border border-stone-100 p-5 rounded-xl flex flex-col items-center text-center group hover:bg-white transition-colors">
                            <span class="material-symbols-outlined text-primary-dark mb-2 text-xl">contact_support</span>
                            <span class="text-[10px] uppercase tracking-wider text-stone-500 font-bold leading-tight">Need Help?</span>
                        </a>
                        <a href="/collections" class="bg-white/50 border border-stone-100 p-5 rounded-xl flex flex-col items-center text-center group hover:bg-white transition-colors">
                            <span class="material-symbols-outlined text-sage-green mb-2 text-xl">redeem</span>
                            <span class="text-[10px] uppercase tracking-wider text-stone-500 font-bold leading-tight">Gift Guide</span>
                        </a>
                    </div>
                </div>
            </div>
        }
        else
        {
            @* Error state *@
            <div class="max-w-xl mx-auto text-center py-16">
                <div class="bg-white rounded-2xl border border-stone-200 p-8 md:p-12">
                    <div class="w-16 h-16 mx-auto mb-6 rounded-full bg-red-100 flex items-center justify-center">
                        <span class="material-symbols-outlined text-3xl text-red-400">error</span>
                    </div>
                    <h1 class="font-display text-2xl text-stone-800 mb-3">Something Went Wrong</h1>
                    <p class="text-stone-500 font-light mb-8">@errorMessage</p>
                    <a href="/checkout"
                       class="inline-flex items-center gap-2 bg-stone-800 text-white px-8 py-3 rounded-full font-bold text-sm uppercase tracking-wider hover:bg-primary transition-all">
                        <span class="material-symbols-outlined text-base">arrow_back</span>
                        <span>Return to Checkout</span>
                    </a>
                </div>
            </div>
        }
    </div>
</main>

@* Custom footer — always visible *@
<footer class="bg-stone-900 text-stone-300 py-16">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 text-center">
        <a class="font-display text-2xl tracking-[0.3em] text-white flex items-center justify-center gap-2 mb-8" href="/">
            <span class="material-symbols-outlined text-primary font-light">spa</span>
            with love
        </a>
        <div class="flex justify-center gap-8 mb-8 text-xs uppercase tracking-widest text-stone-500">
            <a class="hover:text-primary transition-colors" href="/about">Our Story</a>
            <a class="hover:text-primary transition-colors" href="/sustainability">Sustainability</a>
            <a class="hover:text-primary transition-colors" href="/contact">Contact</a>
        </div>
        <p class="text-[10px] tracking-widest text-stone-600">
            &copy; @DateTime.Now.Year WITH LOVE COLLECTIVE. CURATED WITH INTENTION. <br />
            <span class="inline-block mt-4">
                <a class="hover:text-stone-300 transition-colors" href="/privacy">Privacy Policy</a> &bull;
                <a class="hover:text-stone-300 transition-colors" href="/terms">Terms of Service</a>
            </span>
        </p>
    </div>
</footer>

@code {
    private bool isLoading = true;
    private bool paymentVerified;
    private string? customerEmail;
    private string errorMessage = "We couldn't verify your payment. Please contact support if you were charged.";

    private string confirmationNumber = "";
    private List<OrderLineItem> lineItems = [];
    private string recipientName = "";
    private string streetAddress = "";
    private string cityPostal = "";
    private string state = "";
    private string country = "";
    private string? giftMessage;
    private string paymentMethodDisplay = "Card";
    private decimal totalPaid;
    private string? receiptUrl;

    private record OrderLineItem(string Name, string? Description, string? ImageUrl, decimal Amount, long Quantity);

    protected override async Task OnInitializedAsync()
    {
        await CartService.InitializeFromAuthAsync(AuthStateProvider, AnonSession);

        var uri = new Uri(Navigation.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("session_id", out var sessionId) || string.IsNullOrEmpty(sessionId))
        {
            errorMessage = "No order session found. Please return to checkout.";
            isLoading = false;
            return;
        }

        try
        {
            var options = new Stripe.Checkout.SessionGetOptions
            {
                Expand = ["line_items.data.price.product", "payment_intent.payment_method", "payment_intent.latest_charge"]
            };
            var session = await StripeClient.V1.Checkout.Sessions.GetAsync(sessionId!, options);

            if (session.PaymentStatus == "paid")
            {
                paymentVerified = true;
                customerEmail = session.CustomerDetails?.Email;

                confirmationNumber = OrderInfo.GenerateConfirmationNumber(session.Id);

                // Total
                totalPaid = (session.AmountTotal ?? 0) / 100m;

                // Line items
                if (session.LineItems?.Data is not null)
                {
                    lineItems = session.LineItems.Data.Select(li => new OrderLineItem(
                        li.Description ?? "Item",
                        null,
                        li.Price?.Product?.Images?.FirstOrDefault(),
                        (li.AmountTotal) / 100m,
                        li.Quantity ?? 1
                    )).ToList();
                }

                // Shipping from CollectedInformation
                var shipping = session.CollectedInformation?.ShippingDetails;
                recipientName = shipping?.Name ?? "";
                streetAddress = shipping?.Address?.Line1 ?? "";
                var city = shipping?.Address?.City ?? "";
                var postal = shipping?.Address?.PostalCode ?? "";
                cityPostal = $"{city}, {postal}".Trim(',', ' ');
                if (cityPostal == ",") cityPostal = "";
                state = shipping?.Address?.State ?? "";
                country = shipping?.Address?.Country ?? "";

                // Gift message from metadata
                giftMessage = session.Metadata?.GetValueOrDefault("gift_message");
                if (string.IsNullOrWhiteSpace(giftMessage)) giftMessage = null;

                // Payment method (best-effort)
                try
                {
                    var card = session.PaymentIntent?.PaymentMethod?.Card;
                    if (card is not null)
                    {
                        var brand = card.Brand ?? "Card";
                        var last4 = card.Last4 ?? "****";
                        paymentMethodDisplay = $"{char.ToUpper(brand[0])}{brand[1..]} .... {last4}";
                    }
                }
                catch { /* fall back to generic "Card" */ }

                // Stripe hosted receipt URL
                receiptUrl = session.PaymentIntent?.LatestCharge?.ReceiptUrl;

                await CartService.ClearAsync();
            }
            else
            {
                errorMessage = "Your payment has not been completed. Please try again.";
            }
        }
        catch (Stripe.StripeException)
        {
            errorMessage = "We couldn't verify your payment. Please contact support if you were charged.";
        }

        isLoading = false;
    }
}
